# ─────────────────────────────────────────────────────────────
#  AppX Uploader Bot — Environment Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs that have admin rights
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# ── Database ──────────────────────────────────────────────────
DB_PATH=appx_bot.db

# ── Directories ───────────────────────────────────────────────
TEMP_DIR=temp
LOG_DIR=logs

# ── Download settings ─────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=5
DOWNLOAD_TIMEOUT=300
MAX_CONCURRENT_DOWNLOADS=3
CHUNK_SIZE=1048576
MAX_FILE_SIZE_MB=2000

# ── Rate limiting ─────────────────────────────────────────────
# Max commands per user per period (seconds)
RATE_LIMIT_CALLS=10
RATE_LIMIT_PERIOD=60

# ── Access control ────────────────────────────────────────────
# Set to "true" to restrict bot to ADMIN_IDS only
ADMIN_ONLY_MODE=false

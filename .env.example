# ═══════════════════════════════════════════════════════════════
#  AppX Uploader Bot v3 — Environment Configuration
#  Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────────────
BOT_TOKEN=123456789:ABCDEFabcdef-your-bot-token-here
ADMIN_IDS=123456789,987654321

# ── Bot Identity ─────────────────────────────────────────────────
BOT_NAME=AppX Uploader Bot
BOT_USERNAME=appx_uploader_bot
SUPPORT_USERNAME=your_support_username
CHANNEL_ID=@your_channel

# ── AppX Login (for CDN cookie auth) ────────────────────────────
APPX_EMAIL=your@email.com
APPX_PASSWORD=yourpassword
# OR paste a raw cookie string directly:
APPX_COOKIE=

# ── DRM Keys (kid:key pairs, comma separated) ───────────────────
DRM_KEYS=abc123def456:789abcdef012,aabbccdd1122:33445566778899aa

# ── yt-dlp ───────────────────────────────────────────────────────
YTDLP_COOKIES_FILE=cookies.txt
YTDLP_EXTRA_ARGS=

# ── HTTP Proxy ────────────────────────────────────────────────────
HTTP_PROXY=
# Example: HTTP_PROXY=http://user:pass@proxy.example.com:8080

# ── Web API Server ────────────────────────────────────────────────
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET=change_this_to_a_strong_secret
API_DOMAIN=https://mybot.example.com

# ── File Paths ────────────────────────────────────────────────────
DB_PATH=appx_bot.db
TEMP_DIR=temp
LOG_DIR=logs
ASSETS_DIR=assets

# ── Download Limits ───────────────────────────────────────────────
MAX_RETRIES=5
RETRY_DELAY=5
DOWNLOAD_TIMEOUT=600
MAX_FILE_SIZE_MB=4000
CHUNK_SIZE=2097152
MAX_PARALLEL_DL=1

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_CALLS=20
RATE_LIMIT_PERIOD=60

# ── Access Control ────────────────────────────────────────────────
ADMIN_ONLY_MODE=false
REQUIRE_JOIN_CHANNEL=
MAX_JOBS_PER_USER=1
MAINTENANCE_MODE=false

# ── UI / Image Generation ─────────────────────────────────────────
WELCOME_IMAGE_ENABLED=true
BOT_THEME_COLOR=#6C63FF
BOT_ACCENT_COLOR=#FF6584
BOT_LOGO_EMOJI=🤖
